# LLM (OpenAI-compatible API) for Proactive pitch generation
# Copy to .env and set your key.

# Required for LLM: API key (OpenAI or compatible)
LLM_API_KEY=sk-your-key-here
# Or use OpenAI's env name:
# OPENAI_API_KEY=sk-your-key-here

# Optional: custom endpoint (e.g. Azure, local model)
# LLM_BASE_URL=https://your-api.com/v1
# OPENAI_BASE_URL=https://your-api.com/v1

# Optional: model name (default: gpt-4o-mini)
# LLM_MODEL=gpt-4o-mini

# Optional: timeout in seconds (default: 45)
# LLM_TIMEOUT_SEC=45

# Optional: max seconds for one reactive/active pitch request (default: 60). Increase if first request times out (e.g. 180).
# RAG_REQUEST_TIMEOUT=180

# --- Hugging Face (for RAG embedding/reranker models) ---
# If you see "timed out" when loading sentence-transformers (e.g. all-MiniLM-L6-v2),
# use a mirror (e.g. in China) or offline mode after the model is cached once.
# Mirror (recommended if huggingface.co is slow or blocked):
# HF_ENDPOINT=https://hf-mirror.com
# Offline (use only local cache; set after model has been downloaded once):
# HF_HUB_OFFLINE=1
